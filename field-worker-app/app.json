{
  "expo": {
    "name": "Civix Field Worker",
    "slug": "civix-field-worker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": false },
    "android": { "adaptiveIcon": { "backgroundColor": "#FFFFFF" } },
    "platforms": ["ios", "android", "web"],
    "web": { "bundler": "metro", "output": "single" },
    "plugins": [
      [
        "expo-camera",
        { "cameraPermission": "Allow Civix Field Worker to access your camera." }
      ],
      [
        "expo-location",
        { "locationAlwaysAndWhenInUsePermission": "Allow Civix Field Worker to use your location." }
      ]
    ]
  }
}
