# ─── LLM Providers ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...

# ─── LangSmith Tracing ──────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=civix-pulse

# ─── Pinecone (Vector DB) ───────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=civix-pulse-events

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/civix_pulse
POSTGRES_URL=postgresql://civix:civix_dev@localhost:5432/civix_pulse

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT Auth ────────────────────────────────────────────
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256

# ─── Application ─────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
FASTAPI_PORT=8000
