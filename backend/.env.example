# ═══════════════════════════════════════════════════════════
# Civix-Pulse Backend — Environment Variables
# ═══════════════════════════════════════════════════════════

# ─── REQUIRED: LLM Provider (OpenRouter — free models) ───
# Get a free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ─── OPTIONAL: LangSmith Tracing (observability dashboard)
# Sign up at: https://smith.langchain.com — set to false to disable
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=civix-pulse

# ─── FUTURE: Pinecone (Vector DB for cluster detection) ──
# Currently mocked with random similarity. Wire up when ready.
# PINECONE_API_KEY=...
# PINECONE_INDEX_NAME=civix-pulse-events

# ─── FUTURE: PostgreSQL + PostGIS (spatial officer dispatch)
# Currently mocked with hardcoded officer. Wire up when ready.
# POSTGRES_URL=postgresql://civix:civix_dev@localhost:5432/civix_pulse

# ─── Application ─────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
FASTAPI_PORT=8000
