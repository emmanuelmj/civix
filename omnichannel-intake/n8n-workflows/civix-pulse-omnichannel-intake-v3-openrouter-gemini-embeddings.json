    {
      "parameters": {
        "jsCode": "const binaryData = $input.first().binary?.data;\nif (!binaryData) {\n  return [{ json: { base64Image: null, mimeType: null } }];\n}\nconst base64 = binaryData.data;\nconst mimeType = binaryData.mimeType || 'image/jpeg';\nreturn [{ json: { base64Image: base64, mimeType: mimeType } }];"
      },
      "id": "f7c6e154-9eba-45ce-a4ca-9133ce5b615e",
      "name": "Convert Image to Base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
