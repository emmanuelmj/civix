    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer sk-or-v1-REDACTED"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "HTTP-Referer",
              "value": "https://civix-pulse.app"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"model\": \"meta-llama/llama-3.2-11b-vision-instruct:free\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Describe the municipal or infrastructure issue visible in this image in one detailed sentence. Focus on: road condition, water, electricity, construction, or emergency hazards. If no issue is visible, respond with exactly: No issue detected.\"\n        },\n        {\n          \"type\": \"image_url\",\n          \"image_url\": {\n            \"url\": \"data:{{ $json.mimeType }};base64,{{ $json.base64Image }}\"\n          }\n        }\n      ]\n    }\n  ],\n  \"max_tokens\": 300\n}",
        "options": {}
      },
      "id": "19ca6333-7ea4-4679-80bc-abf03562ca4d",
      "name": "OpenRouter Vision",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4400,
        576
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\n// From Text branch\nif (data.text && typeof data.text === 'string' && !data.choices && !data.candidates) {\n  return [{ json: { unified_text: data.text, source_type: 'text' } }];\n}\n\n// From Groq Whisper (returns { text: '...' })\nif (data.text && typeof data.text === 'string' && !data.choices) {\n  return [{ json: { unified_text: data.text, source_type: 'audio' } }];\n}\n\n// From OpenRouter Vision or Classification (OpenAI-compatible: choices[0].message.content)\nif (data.choices && data.choices[0]) {\n  const content = data.choices[0].message.content;\n  return [{ json: { unified_text: content, source_type: 'image' } }];\n}\n\n// Location pin drop\nif (data.latitude && data.longitude) {\n  return [{ json: { unified_text: 'Citizen dropped a location pin', source_type: 'location' } }];\n}\n\nreturn [{ json: { unified_text: 'No content extracted', source_type: 'unknown' } }];"
      },
      "id": "a0b41c09-08ed-4452-a03f-5bdc174b248f",
      "name": "Merge to Unified Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4640,
        480
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer gsk_REDACTED"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "HTTP-Referer",
              "value": "https://civix-pulse.app"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an AI classifier for Civix-Pulse, a smart city grievance system in Hyderabad, India. You will receive a citizen complaint in English, Telugu, Hindi, or mixed Hyderabadi slang. Your job: 1. Translate any local slang or regional language to formal English. 2. Score the emotional sentiment from 1-10 (10 = extreme panic or emergency). 3. Set panic_flag to true if score is 8 or above. 4. Classify domain strictly as one of: MUNICIPAL, TRAFFIC, CONSTRUCTION, EMERGENCY. 5. Identify a specific issue_type such as Pothole, Water Leakage, Live Wire, Road Blockage, Garbage, Flooding, Power Outage, Sewage Overflow. Respond ONLY with valid JSON, no extra text, no markdown, no backticks: {\\\"translated_description\\\": \\\"...\\\", \\\"domain\\\": \\\"...\\\", \\\"issue_type\\\": \\\"...\\\", \\\"sentiment_score\\\": 0, \\\"panic_flag\\\": false}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ $json.unified_text }}\"\n    }\n  ],\n  \"temperature\": 0.1,\n  \"max_tokens\": 500,\n  \"response_format\": { \"type\": \"json_object\" }\n}",
        "options": {}
      },
      "id": "0d252101-2023-4973-aac7-849ba4c93c5c",
      "name": "OpenRouter Classification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        4880,
        480
      ]
    },
    {
      "parameters": {
        "jsCode": "const classifyOutput = $input.first().json;\nconst extractedData = $('Extract Message Data').first().json;\n\nlet ai;\ntry {\n  const rawText = classifyOutput.choices[0].message.content;\n  const clean = rawText.replace(/```json|```/g, '').trim();\n  ai = JSON.parse(clean);\n} catch(e) {\n  ai = {\n    translated_description: 'Unable to parse complaint',\n    domain: 'MUNICIPAL',\n    issue_type: 'Unknown',\n    sentiment_score: 5,\n    panic_flag: false\n  };\n}\n\nconst uuid = () => 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n  const r = Math.random() * 16 | 0;\n  return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n});\n\nlet rawInput = extractedData.text;\nif (!rawInput && extractedData.audio_id) rawInput = 'Voice note transcribed';\nif (!rawInput && extractedData.image_id) rawInput = 'Image received';\nif (!rawInput && extractedData.latitude) rawInput = 'Location pin dropped';\n\nconst pulseEvent = {\n  event_id: uuid(),\n  timestamp: new Date().toISOString(),\n  source: 'whatsapp',\n  citizen_id: extractedData.phone,\n  citizen_name: extractedData.name,\n  raw_input: rawInput,\n  multimodal_urls: {\n    image_url: extractedData.image_id ? `https://graph.facebook.com/v19.0/${extractedData.image_id}` : null,\n    audio_url: extractedData.audio_id ? `https://graph.facebook.com/v19.0/${extractedData.audio_id}` : null\n  },\n  ai_analysis: {\n    translated_description: ai.translated_description,\n    domain: ai.domain,\n    issue_type: ai.issue_type,\n    sentiment_score: ai.sentiment_score,\n    panic_flag: ai.panic_flag\n  },\n  location: {\n    provided_text: extractedData.text || null,\n    latitude: extractedData.latitude || null,\n    longitude: extractedData.longitude || null\n  },\n  embed_text: ai.translated_description\n};\n\nreturn [{ json: pulseEvent }];"
      },
