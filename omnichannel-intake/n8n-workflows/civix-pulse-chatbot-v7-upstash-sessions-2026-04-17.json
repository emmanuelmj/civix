    {
      "parameters": {
        "jsCode": "// Build Partial Pulse + Save to Upstash\nconst UPSTASH_URL = 'https://clever-seal-100902.upstash.io';\nconst UPSTASH_TOKEN = 'gQAAAAAAAYomAAIocDIwY2E4MDY1ZmVkMWQ0M2ZhODM0ZWQ1OTZmODI5OGEyZHAyMTAwOTAy';\n\nconst classifyOutput = $input.first().json;\nconst rawData = $('Extract Message Data').first().json;\n\nlet ai;\ntry {\n  ai = JSON.parse(classifyOutput.choices[0].message.content.replace(/```json|```/g,'').trim());\n} catch(e) {\n  ai = { translated_description: 'Unable to parse', domain: 'MUNICIPAL', issue_type: 'Unknown', sentiment_score: 5, panic_flag: false, location_hint: '', needs_photo: false };\n}\n\nconst uuid = () => 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => { const r=Math.random()*16|0; return (c==='x'?r:(r&0x3|0x8)).toString(16); });\n\nconst partialPulse = {\n  event_id: uuid(),\n  timestamp: new Date().toISOString(),\n  source: 'whatsapp',\n  citizen_id: rawData.phone,\n  citizen_name: rawData.name || '',\n  raw_input: rawData.text || (rawData.audio_id ? 'Voice note' : rawData.image_id ? 'Image' : 'Unknown'),\n  multimodal_urls: {\n    image_url: rawData.image_id ? 'https://graph.facebook.com/v19.0/' + rawData.image_id : null,\n    audio_url: rawData.audio_id ? 'https://graph.facebook.com/v19.0/' + rawData.audio_id : null\n  },\n  ai_analysis: {\n    translated_description: ai.translated_description,\n    domain: ai.domain,\n    issue_type: ai.issue_type,\n    sentiment_score: ai.sentiment_score,\n    panic_flag: ai.panic_flag,\n    location_hint: ai.location_hint || '',\n    needs_photo: ai.needs_photo\n  },\n  location: {\n    provided_text: rawData.text || null,\n    latitude: null,\n    longitude: null,\n    location_hint: ai.location_hint || ''\n  },\n  embed_text: ai.translated_description\n};\n\n// Save session to Upstash with 1 hour TTL\nconst sessionKey = 'civix_session_' + rawData.phone;\nconst sessionData = {\n  phase: 'awaiting_location',\n  partial_pulse: partialPulse,\n  created_at: new Date().toISOString()\n};\n\ntry {\n  await $http.request({\n    method: 'SET',\n    url: `${UPSTASH_URL}/set/${sessionKey}/EX/3600`,\n    headers: { 'Authorization': `Bearer ${UPSTASH_TOKEN}`, 'Content-Type': 'application/json' },\n    body: JSON.stringify(JSON.stringify(sessionData))\n  });\n} catch(e) {\n  // Fallback — try simpler set\n  try {\n    await $http.request({\n      method: 'POST',\n      url: `${UPSTASH_URL}/set/${sessionKey}`,\n      headers: { 'Authorization': `Bearer ${UPSTASH_TOKEN}`, 'Content-Type': 'application/json' },\n      body: JSON.stringify({ value: JSON.stringify(sessionData) })\n    });\n  } catch(e2) {}\n}\n\nreturn [{ json: { ...partialPulse, chat_action: 'ask_location' } }];"
      },
