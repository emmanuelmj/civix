    {
      "parameters": {
        "jsCode": "// ============================================\n// SESSION MANAGER v7 - Upstash Redis Persistence\n// Works in test webhook mode\n// ============================================\n\nconst UPSTASH_URL = 'https://clever-seal-100902.upstash.io';\nconst UPSTASH_TOKEN = 'gQAAAAAAAYomAAIocDIwY2E4MDY1ZmVkMWQ0M2ZhODM0ZWQ1OTZmODI5OGEyZHAyMTAwOTAy';\nconst PHOTO_REQUIRED = ['Pothole', 'Waterlogging', 'Garbage', 'Flooding', 'Road Blockage', 'Sewage Overflow', 'Water Leakage', 'Construction Hazard', 'Live Wire'];\n\nconst data = $input.first().json;\nconst phone = data.phone;\nconst sessionKey = 'civix_session_' + phone;\n\n// ---- Helper: Get session from Upstash ----\nasync function getSession() {\n  try {\n    const res = await $http.request({\n      method: 'GET',\n      url: `${UPSTASH_URL}/get/${sessionKey}`,\n      headers: { 'Authorization': `Bearer ${UPSTASH_TOKEN}` }\n    });\n    const body = typeof res === 'string' ? JSON.parse(res) : res;\n    if (body.result && body.result !== null) {\n      return JSON.parse(body.result);\n    }\n    return null;\n  } catch(e) {\n    return null;\n  }\n}\n\n// ---- Helper: Save session to Upstash (TTL 1 hour) ----\nasync function saveSession(sessionData) {\n  try {\n    await $http.request({\n      method: 'POST',\n      url: `${UPSTASH_URL}/set/${sessionKey}`,\n      headers: { 'Authorization': `Bearer ${UPSTASH_TOKEN}`, 'Content-Type': 'application/json' },\n      body: JSON.stringify({ value: JSON.stringify(sessionData), ex: 3600 })\n    });\n  } catch(e) {}\n}\n\n// ---- Helper: Delete session from Upstash ----\nasync function deleteSession() {\n  try {\n    await $http.request({\n      method: 'GET',\n      url: `${UPSTASH_URL}/del/${sessionKey}`,\n      headers: { 'Authorization': `Bearer ${UPSTASH_TOKEN}` }\n    });\n  } catch(e) {}\n}\n\n// ============================================\n// MAIN LOGIC\n// ============================================\nconst session = await getSession();\n\n// ==========================================\n// NO ACTIVE SESSION\n// ==========================================\nif (!session) {\n  if (data.message_type === 'location') {\n    return [{ json: { ...data, chat_action: 'orphan_location' } }];\n  }\n  if (data.message_type === 'text' && data.text && data.text.trim().split(/\\s+/).length < 3) {\n    return [{ json: { ...data, chat_action: 'spam' } }];\n  }\n  return [{ json: { ...data, chat_action: 'new_complaint' } }];\n}\n\n// ==========================================\n// PHASE: awaiting_location\n// ==========================================\nif (session.phase === 'awaiting_location') {\n  if (data.message_type === 'location') {\n    session.partial_pulse.location.latitude = data.latitude;\n    session.partial_pulse.location.longitude = data.longitude;\n    session.partial_pulse.location.source = 'native_pin';\n    const needsPhoto = PHOTO_REQUIRED.includes(session.partial_pulse.ai_analysis.issue_type);\n    if (needsPhoto) {\n      session.phase = 'awaiting_photo';\n      await saveSession(session);\n      return [{ json: { phone: data.phone, name: data.name, issue_type: session.partial_pulse.ai_analysis.issue_type, chat_action: 'ask_photo' } }];\n    } else {\n      const pulse = { ...session.partial_pulse, chat_action: 'complete' };\n      await deleteSession();\n      return [{ json: pulse }];\n    }\n  }\n  if (data.message_type === 'text' && data.text) {\n    session.partial_pulse.location.provided_text = data.text;\n    session.partial_pulse.location.geocode_query = data.text + ', Hyderabad, India';\n    const needsPhoto = PHOTO_REQUIRED.includes(session.partial_pulse.ai_analysis.issue_type);\n    if (needsPhoto) {\n      session.phase = 'awaiting_photo';\n      await saveSession(session);\n      return [{ json: { phone: data.phone, name: data.name, issue_type: session.partial_pulse.ai_analysis.issue_type, chat_action: 'ask_photo' } }];\n    } else {\n      const pulse = { ...session.partial_pulse, chat_action: 'geocode_then_complete' };\n      await deleteSession();\n      return [{ json: pulse }];\n    }\n  }\n  return [{ json: { phone: data.phone, name: data.name, chat_action: 'remind_location' } }];\n}\n\n// ==========================================\n// PHASE: awaiting_photo\n// ==========================================\nif (session.phase === 'awaiting_photo') {\n  if (data.message_type === 'image') {\n    session.partial_pulse.multimodal_urls.image_url = 'https://graph.facebook.com/v19.0/' + data.image_id;\n    const pulse = { ...session.partial_pulse, chat_action: 'complete' };\n    await deleteSession();\n    return [{ json: pulse }];\n  }\n  if (data.message_type === 'text' && data.text && data.text.toLowerCase().trim() === 'skip') {\n    const pulse = { ...session.partial_pulse, chat_action: 'complete' };\n    await deleteSession();\n    return [{ json: pulse }];\n  }\n  return [{ json: { phone: data.phone, name: data.name, chat_action: 'remind_photo' } }];\n}\n\nreturn [{ json: { ...data, chat_action: 'new_complaint' } }];"
      },
