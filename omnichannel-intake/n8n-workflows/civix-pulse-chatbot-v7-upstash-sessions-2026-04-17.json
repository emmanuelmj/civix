        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an AI classifier for Civix-Pulse in Hyderabad, India. Classify the complaint and respond ONLY with valid JSON, no markdown: {\\\"translated_description\\\": \\\"...\\\", \\\"domain\\\": \\\"MUNICIPAL|TRAFFIC|CONSTRUCTION|EMERGENCY\\\", \\\"issue_type\\\": \\\"Pothole|Waterlogging|Water Leakage|Live Wire|Road Blockage|Garbage|Flooding|Power Outage|Sewage Overflow|Construction Hazard|Other\\\", \\\"sentiment_score\\\": 5, \\\"panic_flag\\\": false, \\\"location_hint\\\": \\\"\\\", \\\"needs_photo\\\": true}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"={{ $json.unified_text }}\"\n    }\n  ],\n  \"temperature\": 0.1,\n  \"max_tokens\": 400,\n  \"response_format\": { \"type\": \"json_object\" }\n}",
