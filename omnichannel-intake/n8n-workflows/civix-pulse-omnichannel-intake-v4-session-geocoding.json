    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst phone = data.phone;\nconst sessions = $getWorkflowStaticData('global');\nif (!sessions.pendingEvents) sessions.pendingEvents = {};\nconst pending = sessions.pendingEvents[phone];\n\n// Incoming native location pin + pending complaint = COMPLETE\nif (data.message_type === 'location' && pending) {\n  const completed = { ...pending, latitude: data.latitude, longitude: data.longitude, location_source: 'native_pin', session_action: 'complete' };\n  delete sessions.pendingEvents[phone];\n  return [{ json: completed }];\n}\n\n// Location pin but no pending complaint\nif (data.message_type === 'location' && !pending) {\n  return [{ json: { ...data, session_action: 'orphan_location' } }];\n}\n\n// New complaint — store as pending\nsessions.pendingEvents[phone] = { ...data, session_start: new Date().toISOString() };\nreturn [{ json: { ...data, session_action: 'pending' } }];"
      },
