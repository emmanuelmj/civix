      "id": "684e2257-3300-4421-bcb5-064e2c7af152",
      "name": "Groq Classification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1680,
        240
      ]
    },
    {
      "parameters": {
        "jsCode": "const classifyOutput = $input.first().json;\nconst extractedData = $('Extract Message Data').first().json;\nconst sessionData = $('Session Manager').first().json;\n\nlet ai;\ntry {\n  const rawText = classifyOutput.choices[0].message.content;\n  ai = JSON.parse(rawText.replace(/```json|```/g, '').trim());\n} catch(e) {\n  ai = { translated_description: 'Unable to parse', domain: 'MUNICIPAL', issue_type: 'Unknown', sentiment_score: 5, panic_flag: false, location_hint: '' };\n}\n\nconst uuid = () => 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => { const r = Math.random()*16|0; return (c==='x'?r:(r&0x3|0x8)).toString(16); });\n\nlet rawInput = extractedData.text || (extractedData.audio_id ? 'Voice note transcribed' : null) || (extractedData.image_id ? 'Image received' : null);\n\nconst latitude = sessionData.latitude || extractedData.latitude || null;\nconst longitude = sessionData.longitude || extractedData.longitude || null;\n\nreturn [{ json: {\n  event_id: uuid(),\n  timestamp: new Date().toISOString(),\n  source: 'whatsapp',\n  citizen_id: extractedData.phone,\n  citizen_name: extractedData.name,\n  raw_input: rawInput,\n  multimodal_urls: {\n    image_url: extractedData.image_id ? `https://graph.facebook.com/v19.0/${extractedData.image_id}` : null,\n    audio_url: extractedData.audio_id ? `https://graph.facebook.com/v19.0/${extractedData.audio_id}` : null\n  },\n  ai_analysis: {\n    translated_description: ai.translated_description,\n    domain: ai.domain,\n    issue_type: ai.issue_type,\n    sentiment_score: ai.sentiment_score,\n    panic_flag: ai.panic_flag,\n    location_hint: ai.location_hint || ''\n  },\n  location: {\n    provided_text: extractedData.text || null,\n    latitude: latitude,\n    longitude: longitude,\n    location_hint: ai.location_hint || ''\n  },\n  embed_text: ai.translated_description,\n  session_action: sessionData.session_action\n} }];"
      },
      "id": "9c0dc061-f540-4052-a1d8-eb67ba248b7e",
