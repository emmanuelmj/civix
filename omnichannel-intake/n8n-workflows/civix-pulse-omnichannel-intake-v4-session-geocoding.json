    {
      "parameters": {
        "jsCode": "const pulse = $input.first().json;\nconst query = pulse.location.location_hint || pulse.location.provided_text || '';\nif (!query || query.trim().length < 3) return [{ json: { ...pulse, geocode_query: '', skip_geocode: true } }];\nconst searchQuery = query.includes('Hyderabad') ? query : `${query}, Hyderabad, India`;\nreturn [{ json: { ...pulse, geocode_query: searchQuery, skip_geocode: false } }];"
      },
